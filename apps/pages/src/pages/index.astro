---
import BriefingCaptureForm from '../components/BriefingCaptureForm.astro';

// Get client ID from environment or use default
const CLIENT_ID = import.meta.env.PUBLIC_CLIENT_ID || '32b77973-9965-497d-a7a4-c12af801d79b';
const API_KEY = import.meta.env.PUBLIC_API_KEY;
const API_BASE_URL = import.meta.env.PUBLIC_API_URL || 'https://fw.alquimiazen.com.br';
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CopyZen - Plataforma de Marketing Conversacional</title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body class="bg-gradient-to-b from-gray-50 to-gray-100 min-h-screen">
    <!-- Header -->
    <header class="bg-white shadow">
      <div class="max-w-7xl mx-auto px-6 py-8">
        <h1 class="text-4xl font-bold text-gray-900">🏛️ CopyZen</h1>
        <p class="text-gray-600 text-lg mt-2">
          Plataforma de Automação de Marketing Conversacional via Agentes IA
        </p>
      </div>
    </header>

    <!-- Hero Section with Form -->
    <main class="max-w-7xl mx-auto px-6 py-12">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <!-- Form Column -->
        <div class="lg:col-span-2">
          <!-- Client Selection Section -->
          <div class="mb-8 bg-gradient-to-r from-blue-50 to-indigo-50 rounded-lg shadow-lg p-6 border border-blue-200">
            <h2 class="text-xl font-bold text-gray-900 mb-4">👤 Selecionar Cliente</h2>

            <div class="space-y-4">
              <!-- Client Dropdown -->
              <div>
                <label for="clientSelect" class="block text-sm font-medium text-gray-700 mb-2">
                  Cliente
                </label>
                <div class="flex gap-2">
                  <select
                    id="clientSelect"
                    class="flex-1 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition"
                  >
                    <option value="">Carregando clientes...</option>
                  </select>
                  <button
                    id="newClientBtn"
                    class="px-4 py-2 bg-green-600 hover:bg-green-700 text-white font-semibold rounded-lg transition"
                  >
                    ➕ Novo
                  </button>
                </div>
              </div>

              <!-- Client Info Display -->
              <div id="clientInfo" class="hidden bg-white rounded-lg p-4 border border-gray-200">
                <p class="text-sm text-gray-600">
                  <strong>ID:</strong> <code id="selectedClientId" class="bg-gray-100 px-2 py-1 rounded text-xs"></code>
                </p>
                <p id="clientName" class="text-sm text-gray-600 mt-2">
                  <strong>Nome:</strong> <span id="selectedClientName"></span>
                </p>
              </div>
            </div>
          </div>

          <BriefingCaptureForm clientId={CLIENT_ID} apiKey={API_KEY} />
        </div>

        <!-- Info Column -->
        <div class="space-y-8">

          <!-- Status Card -->
          <div class="bg-white rounded-lg shadow-lg p-6">
            <h2 class="text-xl font-bold text-gray-900 mb-4">📊 Status</h2>
            <div class="space-y-2 text-gray-700 text-sm">
              <p>✅ Seleção de cliente</p>
              <p>✅ Criação de cliente</p>
              <p>✅ Formulário de briefing</p>
              <p>✅ Salvamento no BD</p>
            </div>
          </div>

          <!-- Quick Start Card -->
          <div class="bg-blue-50 rounded-lg shadow-lg p-6 border border-blue-200">
            <h2 class="text-xl font-bold text-blue-900 mb-4">🚀 Próximos Passos</h2>
            <ol class="list-decimal list-inside space-y-2 text-blue-900 text-sm">
              <li>Preencha o formulário ao lado</li>
              <li>Aguarde a confirmação da API</li>
              <li>Acesse o painel de controle</li>
              <li>Configure sua marca</li>
              <li>Gere conteúdo automaticamente</li>
            </ol>
          </div>

          <!-- Documentation Card -->
          <div class="bg-green-50 rounded-lg shadow-lg p-6 border border-green-200">
            <h2 class="text-xl font-bold text-green-900 mb-4">📚 Documentação</h2>
            <ul class="space-y-2 text-sm text-green-900">
              <li>
                <a
                  href="/docs/architecture.md"
                  class="text-green-700 hover:text-green-900 underline"
                >
                  Arquitetura Técnica
                </a>
              </li>
              <li>
                <a
                  href="/docs/prd.md"
                  class="text-green-700 hover:text-green-900 underline"
                >
                  Requisitos do Produto
                </a>
              </li>
              <li>
                <a
                  href="/docs/API_AUTHENTICATION.md"
                  class="text-green-700 hover:text-green-900 underline"
                >
                  Autenticação da API
                </a>
              </li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Features Section -->
      <div class="mt-20">
        <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">✨ Funcionalidades</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="bg-white rounded-lg shadow-lg p-6">
            <div class="text-3xl mb-3">🧠</div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">Geração com IA</h3>
            <p class="text-gray-600">
              Conteúdo gerado automaticamente usando Claude API respeitando seu tom de marca
            </p>
          </div>
          <div class="bg-white rounded-lg shadow-lg p-6">
            <div class="text-3xl mb-3">🎨</div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">Identidade de Marca</h3>
            <p class="text-gray-600">
              Configure suas cores, tom de voz e diretrizes que serão respeitadas em todo conteúdo
            </p>
          </div>
          <div class="bg-white rounded-lg shadow-lg p-6">
            <div class="text-3xl mb-3">⚡</div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">Orquestração</h3>
            <p class="text-gray-600">
              Workflows automáticos que conectam briefing, branding, copywriting e publicação
            </p>
          </div>
        </div>
      </div>

      <!-- Footer -->
      <footer class="mt-20 py-8 border-t border-gray-200 text-center text-gray-600">
        <p>CopyZen © 2026 - Plataforma de Automação de Marketing</p>
        <p class="text-sm mt-2">Versão 1.0 - Em desenvolvimento</p>
      </footer>
    </main>

    <!-- Modal: Create New Client -->
    <div id="newClientModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 p-4">
      <div class="bg-white rounded-lg shadow-xl max-w-md w-full max-h-[90vh] overflow-y-auto">
        <div class="sticky top-0 bg-gradient-to-r from-green-600 to-emerald-600 px-6 py-4 text-white flex justify-between items-center">
          <h2 class="text-xl font-bold">➕ Criar Novo Cliente</h2>
          <button id="closeModalBtn" class="text-2xl hover:bg-green-700 w-8 h-8 rounded flex items-center justify-center">
            ✕
          </button>
        </div>

        <form id="newClientForm" class="p-6 space-y-4">
          <!-- Client Name -->
          <div>
            <label for="clientName" class="block text-sm font-medium text-gray-700 mb-1">
              Nome do Cliente <span class="text-red-500">*</span>
            </label>
            <input
              type="text"
              id="clientName"
              name="name"
              placeholder="Ex: Clínica Silva, Agência XYZ"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent outline-none transition"
              required
            />
          </div>

          <!-- Industry -->
          <div>
            <label for="clientIndustry" class="block text-sm font-medium text-gray-700 mb-1">
              Segmento <span class="text-red-500">*</span>
            </label>
            <input
              type="text"
              id="clientIndustry"
              name="industry"
              placeholder="Ex: Healthcare, Tech, E-commerce"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent outline-none transition"
              required
            />
          </div>

          <!-- Contact Name -->
          <div>
            <label for="contactName" class="block text-sm font-medium text-gray-700 mb-1">
              Nome do Contato
            </label>
            <input
              type="text"
              id="contactName"
              name="contact_name"
              placeholder="Ex: João Silva"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent outline-none transition"
            />
          </div>

          <!-- Contact Email -->
          <div>
            <label for="contactEmail" class="block text-sm font-medium text-gray-700 mb-1">
              Email
            </label>
            <input
              type="email"
              id="contactEmail"
              name="contact_email"
              placeholder="joao@exemplo.com"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent outline-none transition"
            />
          </div>

          <!-- Contact Phone -->
          <div>
            <label for="contactPhone" class="block text-sm font-medium text-gray-700 mb-1">
              Telefone
            </label>
            <input
              type="tel"
              id="contactPhone"
              name="contact_phone"
              placeholder="(11) 99999-9999"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent outline-none transition"
            />
          </div>

          <!-- Website -->
          <div>
            <label for="website" class="block text-sm font-medium text-gray-700 mb-1">
              Website
            </label>
            <input
              type="url"
              id="website"
              name="website"
              placeholder="https://exemplo.com"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent outline-none transition"
            />
          </div>

          <!-- Error Alert -->
          <div id="createClientError" class="hidden bg-red-50 border border-red-200 rounded-lg p-3">
            <p id="createClientErrorMessage" class="text-red-800 text-sm"></p>
          </div>

          <!-- Success Alert -->
          <div id="createClientSuccess" class="hidden bg-green-50 border border-green-200 rounded-lg p-3">
            <p class="text-green-800 text-sm">✅ Cliente criado com sucesso!</p>
          </div>

          <!-- Buttons -->
          <div class="flex gap-2 pt-4">
            <button
              type="button"
              id="cancelCreateBtn"
              class="flex-1 px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 font-medium transition"
            >
              Cancelar
            </button>
            <button
              type="submit"
              id="submitCreateBtn"
              class="flex-1 px-4 py-2 bg-green-600 hover:bg-green-700 text-white font-medium rounded-lg transition"
            >
              Criar Cliente
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Client Management Script -->
    <script define:vars={{ API_BASE_URL }}>
      let allClients = [];
      let selectedClient = null;

      // Initialize client management
      async function initializeClients() {
        await loadClients();
        setupEventListeners();
      }

      // Load clients from API
      async function loadClients() {
        try {
          const response = await fetch(`${API_BASE_URL}/api/clients-public`);
          if (response.ok) {
            const data = await response.json();
            allClients = data.data || [];
            populateClientDropdown();
          }
        } catch (error) {
          console.error('Erro ao carregar clientes:', error);
        }
      }

      // Populate dropdown with clients
      function populateClientDropdown() {
        const select = document.getElementById('clientSelect');
        if (!select) return;

        select.innerHTML = '<option value="">-- Selecione um cliente --</option>';
        allClients.forEach((client) => {
          const option = document.createElement('option');
          option.value = client.id;
          option.textContent = client.name;
          select.appendChild(option);
        });

        // Set default to first client if available
        if (allClients.length > 0) {
          select.value = allClients[0].id;
          selectClient(allClients[0].id);
        }
      }

      // Select client
      function selectClient(clientId) {
        selectedClient = allClients.find((c) => c.id === clientId);
        if (selectedClient) {
          // Update client info display
          const clientInfo = document.getElementById('clientInfo');
          const selectedClientId = document.getElementById('selectedClientId');
          const selectedClientName = document.getElementById('selectedClientName');

          if (clientInfo) {
            clientInfo.classList.remove('hidden');
            selectedClientId.textContent = clientId;
            selectedClientName.textContent = selectedClient.name;
          }

          // Update form with selected client
          window.ACTIVE_CLIENT_ID = clientId;
          localStorage.setItem('copyzen_client_id', clientId);
        }
      }

      // Setup event listeners
      function setupEventListeners() {
        // Client dropdown
        const select = document.getElementById('clientSelect');
        if (select) {
          select.addEventListener('change', (e) => {
            if (e.target.value) {
              selectClient(e.target.value);
            }
          });
        }

        // New client button
        const newClientBtn = document.getElementById('newClientBtn');
        if (newClientBtn) {
          newClientBtn.addEventListener('click', () => {
            document.getElementById('newClientModal').classList.remove('hidden');
          });
        }

        // Close modal
        const closeModalBtn = document.getElementById('closeModalBtn');
        const cancelCreateBtn = document.getElementById('cancelCreateBtn');
        const modal = document.getElementById('newClientModal');

        [closeModalBtn, cancelCreateBtn].forEach((btn) => {
          if (btn) {
            btn.addEventListener('click', () => {
              modal.classList.add('hidden');
              document.getElementById('newClientForm').reset();
              document.getElementById('createClientError').classList.add('hidden');
              document.getElementById('createClientSuccess').classList.add('hidden');
            });
          }
        });

        // Close modal when clicking outside
        if (modal) {
          modal.addEventListener('click', (e) => {
            if (e.target === modal) {
              modal.classList.add('hidden');
            }
          });
        }

        // Create client form
        const createForm = document.getElementById('newClientForm');
        if (createForm) {
          createForm.addEventListener('submit', handleCreateClient);
        }
      }

      // Handle create client
      async function handleCreateClient(e) {
        e.preventDefault();

        const form = e.target;
        const submitBtn = document.getElementById('submitCreateBtn');
        const errorDiv = document.getElementById('createClientError');
        const errorMsg = document.getElementById('createClientErrorMessage');
        const successDiv = document.getElementById('createClientSuccess');

        submitBtn.disabled = true;
        submitBtn.textContent = 'Criando...';
        errorDiv.classList.add('hidden');
        successDiv.classList.add('hidden');

        try {
          const formData = new FormData(form);
          const payload = Object.fromEntries(formData);

          const response = await fetch(`${API_BASE_URL}/clients`, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify(payload),
          });

          if (response.ok) {
            const result = await response.json();
            successDiv.classList.remove('hidden');

            // Reload clients and select the new one
            await loadClients();
            setTimeout(() => {
              document.getElementById('clientSelect').value = result.data.id;
              selectClient(result.data.id);
              document.getElementById('newClientModal').classList.add('hidden');
              form.reset();
              submitBtn.disabled = false;
              submitBtn.textContent = 'Criar Cliente';
            }, 1500);
          } else {
            const error = await response.json();
            errorMsg.textContent = error.message || 'Erro ao criar cliente';
            errorDiv.classList.remove('hidden');
            submitBtn.disabled = false;
            submitBtn.textContent = 'Criar Cliente';
          }
        } catch (error) {
          errorMsg.textContent = error.message || 'Erro de rede ao criar cliente';
          errorDiv.classList.remove('hidden');
          submitBtn.disabled = false;
          submitBtn.textContent = 'Criar Cliente';
        }
      }

      // Initialize on page load
      document.addEventListener('DOMContentLoaded', initializeClients);
      initializeClients();
    </script>
  </body>
</html>

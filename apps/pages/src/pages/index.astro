---
import BriefingCaptureForm from '../components/BriefingCaptureForm.astro';

// Get client ID from environment or use default (Clínica Silva test account)
// In production, this would be set via PUBLIC_CLIENT_ID env variable or determined by user session
const CLIENT_ID = import.meta.env.PUBLIC_CLIENT_ID || '32b77973-9965-497d-a7a4-c12af801d79b';
const API_KEY = import.meta.env.PUBLIC_API_KEY;
const API_BASE_URL = import.meta.env.PUBLIC_API_URL || 'https://fw.alquimiazen.com.br';
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CopyZen - Plataforma de Marketing Conversacional</title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body class="bg-gradient-to-b from-gray-50 to-gray-100 min-h-screen">
    <!-- Header -->
    <header class="bg-white shadow">
      <div class="max-w-7xl mx-auto px-6 py-8">
        <h1 class="text-4xl font-bold text-gray-900">🏛️ CopyZen</h1>
        <p class="text-gray-600 text-lg mt-2">
          Plataforma de Automação de Marketing Conversacional via Agentes IA
        </p>
      </div>
    </header>

    <!-- Hero Section with Form -->
    <main class="max-w-7xl mx-auto px-6 py-12">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <!-- Form Column -->
        <div class="lg:col-span-2">
          <BriefingCaptureForm clientId={CLIENT_ID} apiKey={API_KEY} />
        </div>

        <!-- Info Column -->
        <div class="space-y-8">
          <!-- Client ID Configuration Card -->
          <div class="bg-blue-50 rounded-lg shadow-lg p-6 border border-blue-200">
            <h2 class="text-xl font-bold text-blue-900 mb-4">🔑 Configuração</h2>
            <div class="space-y-3">
              <div>
                <label class="block text-sm font-medium text-blue-900 mb-2">
                  Client ID:
                </label>
                <input
                  type="text"
                  id="clientIdInput"
                  value={CLIENT_ID}
                  class="w-full px-3 py-2 border border-blue-300 rounded-lg text-sm font-mono bg-white text-blue-900 focus:ring-2 focus:ring-blue-500"
                  placeholder="Digite o UUID do cliente"
                />
              </div>
              <p class="text-xs text-blue-800">
                💡 Mude o Client ID se necessário. É salvo automaticamente.
              </p>
              <div id="clientIdStatus" class="text-sm text-blue-700"></div>
            </div>
          </div>

          <!-- Status Card -->
          <div class="bg-white rounded-lg shadow-lg p-6">
            <h2 class="text-xl font-bold text-gray-900 mb-4">📊 Status do Projeto</h2>
            <div class="space-y-2 text-gray-700">
              <p>✅ Scaffold criado</p>
              <p>✅ API REST implementada</p>
              <p>✅ Banco de dados configurado</p>
              <p>🔄 Formulário de captura ativo</p>
            </div>
          </div>

          <!-- Quick Start Card -->
          <div class="bg-blue-50 rounded-lg shadow-lg p-6 border border-blue-200">
            <h2 class="text-xl font-bold text-blue-900 mb-4">🚀 Próximos Passos</h2>
            <ol class="list-decimal list-inside space-y-2 text-blue-900 text-sm">
              <li>Preencha o formulário ao lado</li>
              <li>Aguarde a confirmação da API</li>
              <li>Acesse o painel de controle</li>
              <li>Configure sua marca</li>
              <li>Gere conteúdo automaticamente</li>
            </ol>
          </div>

          <!-- Documentation Card -->
          <div class="bg-green-50 rounded-lg shadow-lg p-6 border border-green-200">
            <h2 class="text-xl font-bold text-green-900 mb-4">📚 Documentação</h2>
            <ul class="space-y-2 text-sm text-green-900">
              <li>
                <a
                  href="/docs/architecture.md"
                  class="text-green-700 hover:text-green-900 underline"
                >
                  Arquitetura Técnica
                </a>
              </li>
              <li>
                <a
                  href="/docs/prd.md"
                  class="text-green-700 hover:text-green-900 underline"
                >
                  Requisitos do Produto
                </a>
              </li>
              <li>
                <a
                  href="/docs/API_AUTHENTICATION.md"
                  class="text-green-700 hover:text-green-900 underline"
                >
                  Autenticação da API
                </a>
              </li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Features Section -->
      <div class="mt-20">
        <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">✨ Funcionalidades</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="bg-white rounded-lg shadow-lg p-6">
            <div class="text-3xl mb-3">🧠</div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">Geração com IA</h3>
            <p class="text-gray-600">
              Conteúdo gerado automaticamente usando Claude API respeitando seu tom de marca
            </p>
          </div>
          <div class="bg-white rounded-lg shadow-lg p-6">
            <div class="text-3xl mb-3">🎨</div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">Identidade de Marca</h3>
            <p class="text-gray-600">
              Configure suas cores, tom de voz e diretrizes que serão respeitadas em todo conteúdo
            </p>
          </div>
          <div class="bg-white rounded-lg shadow-lg p-6">
            <div class="text-3xl mb-3">⚡</div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">Orquestração</h3>
            <p class="text-gray-600">
              Workflows automáticos que conectam briefing, branding, copywriting e publicação
            </p>
          </div>
        </div>
      </div>

      <!-- Footer -->
      <footer class="mt-20 py-8 border-t border-gray-200 text-center text-gray-600">
        <p>CopyZen © 2026 - Plataforma de Automação de Marketing</p>
        <p class="text-sm mt-2">Versão 1.0 - Em desenvolvimento</p>
      </footer>
    </main>

    <!-- Client ID Management Script -->
    <script define:vars={{ CLIENT_ID, API_BASE_URL }}>
      // Load client ID from query param, localStorage, or use default
      function initializeClientId() {
        const params = new URLSearchParams(window.location.search);
        const queryClientId = params.get('client_id');
        const storedClientId = localStorage.getItem('copyzen_client_id');

        let activeClientId = queryClientId || storedClientId || CLIENT_ID;

        // Update input field
        const clientIdInput = document.getElementById('clientIdInput');
        if (clientIdInput) {
          clientIdInput.value = activeClientId;
        }

        // Update briefing form with current client ID
        updateFormClientId(activeClientId);

        // Store in localStorage for next visit
        if (activeClientId) {
          localStorage.setItem('copyzen_client_id', activeClientId);
        }

        // Show status
        updateClientIdStatus(activeClientId);
      }

      function updateFormClientId(clientId) {
        // Store in window for form to access
        window.ACTIVE_CLIENT_ID = clientId;
      }

      function updateClientIdStatus(clientId) {
        const status = document.getElementById('clientIdStatus');
        if (status) {
          const shortId = clientId.substring(0, 8) + '...';
          status.textContent = `✅ Usando: ${shortId}`;
        }
      }

      // Handle client ID changes
      const clientIdInput = document.getElementById('clientIdInput');
      if (clientIdInput) {
        clientIdInput.addEventListener('change', (e) => {
          const newClientId = e.target.value.trim();
          if (newClientId) {
            // Validate UUID format
            const uuidRegex = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;
            if (uuidRegex.test(newClientId)) {
              localStorage.setItem('copyzen_client_id', newClientId);
              updateFormClientId(newClientId);
              updateClientIdStatus(newClientId);
            } else {
              alert('❌ ID de cliente inválido! Use um UUID válido.');
              clientIdInput.value = window.ACTIVE_CLIENT_ID;
            }
          }
        });
      }

      // Initialize on page load
      document.addEventListener('DOMContentLoaded', initializeClientId);
      initializeClientId();
    </script>
  </body>
</html>

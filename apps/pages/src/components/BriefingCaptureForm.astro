---
import { OBJECTIVE_LABELS, SEGMENT_LABELS, VOICE_TONE_LABELS } from '../lib/briefing-form-validation';

interface Props {
  clientId: string;
  apiKey?: string;
}

const { clientId, apiKey } = Astro.props;
---

<div class="w-full max-w-2xl mx-auto p-6 bg-white rounded-lg shadow-lg">
  <div class="mb-8">
    <h2 class="text-3xl font-bold text-gray-900 mb-2">
      📋 Preencha seu Briefing
    </h2>
    <p class="text-gray-600">
      Nos forneça as informações essenciais sobre seu negócio para começarmos
    </p>
  </div>

  <form id="briefingForm" class="space-y-6">
    <!-- Business Name -->
    <div>
      <label for="business_name" class="block text-sm font-medium text-gray-700 mb-2">
        Nome do Negócio <span class="text-red-500">*</span>
      </label>
      <input
        type="text"
        id="business_name"
        name="business_name"
        placeholder="Ex: Clínica Silva"
        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition"
        required
      />
      <p id="business_name-error" class="text-red-500 text-sm mt-1 hidden"></p>
    </div>

    <!-- Segment -->
    <div>
      <label for="segment" class="block text-sm font-medium text-gray-700 mb-2">
        Segmento <span class="text-red-500">*</span>
      </label>
      <select
        id="segment"
        name="segment"
        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition"
        required
      >
        <option value="">Selecione um segmento</option>
        <option value="healthcare">Saúde</option>
        <option value="fintech">Fintech</option>
        <option value="ecommerce">E-commerce</option>
        <option value="education">Educação</option>
        <option value="saas">SaaS</option>
        <option value="retail">Varejo</option>
        <option value="other">Outro</option>
      </select>
      <p id="segment-error" class="text-red-500 text-sm mt-1 hidden"></p>
    </div>

    <!-- Target Audience -->
    <div>
      <label for="target_audience" class="block text-sm font-medium text-gray-700 mb-2">
        Público-Alvo <span class="text-red-500">*</span>
      </label>
      <input
        type="text"
        id="target_audience"
        name="target_audience"
        placeholder="Ex: Médicos e pacientes com problemas de saúde"
        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition"
        required
      />
      <p id="target_audience-error" class="text-red-500 text-sm mt-1 hidden"></p>
    </div>

    <!-- Voice Tone -->
    <div>
      <label for="voice_tone" class="block text-sm font-medium text-gray-700 mb-2">
        Tom de Voz <span class="text-red-500">*</span>
      </label>
      <select
        id="voice_tone"
        name="voice_tone"
        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition"
        required
      >
        <option value="">Selecione um tom</option>
        <option value="professional">Profissional</option>
        <option value="casual">Casual</option>
        <option value="empathetic">Empático</option>
        <option value="urgent">Urgente</option>
        <option value="friendly">Amigável</option>
      </select>
      <p id="voice_tone-error" class="text-red-500 text-sm mt-1 hidden"></p>
    </div>

    <!-- Objectives -->
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-3">
        Objetivos <span class="text-red-500">*</span> (selecione pelo menos 1)
      </label>
      <div class="space-y-2">
        <label class="flex items-center">
          <input
            type="checkbox"
            name="objectives"
            value="increase-leads"
            class="w-4 h-4 text-blue-600 rounded focus:ring-blue-500 cursor-pointer"
          />
          <span class="ml-3 text-gray-700">Aumentar Leads</span>
        </label>
        <label class="flex items-center">
          <input
            type="checkbox"
            name="objectives"
            value="boost-sales"
            class="w-4 h-4 text-blue-600 rounded focus:ring-blue-500 cursor-pointer"
          />
          <span class="ml-3 text-gray-700">Impulsionar Vendas</span>
        </label>
        <label class="flex items-center">
          <input
            type="checkbox"
            name="objectives"
            value="build-awareness"
            class="w-4 h-4 text-blue-600 rounded focus:ring-blue-500 cursor-pointer"
          />
          <span class="ml-3 text-gray-700">Construir Presença</span>
        </label>
        <label class="flex items-center">
          <input
            type="checkbox"
            name="objectives"
            value="educate-audience"
            class="w-4 h-4 text-blue-600 rounded focus:ring-blue-500 cursor-pointer"
          />
          <span class="ml-3 text-gray-700">Educar Público</span>
        </label>
        <label class="flex items-center">
          <input
            type="checkbox"
            name="objectives"
            value="other"
            class="w-4 h-4 text-blue-600 rounded focus:ring-blue-500 cursor-pointer"
          />
          <span class="ml-3 text-gray-700">Outro</span>
        </label>
      </div>
      <p id="objectives-error" class="text-red-500 text-sm mt-2 hidden"></p>
    </div>

    <!-- Differentiators -->
    <div>
      <label for="differentiators" class="block text-sm font-medium text-gray-700 mb-2">
        Diferenciadores <span class="text-red-500">*</span>
      </label>
      <textarea
        id="differentiators"
        name="differentiators"
        placeholder="O que torna seu negócio único?"
        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition resize-none"
        rows="3"
        required
      ></textarea>
      <p id="differentiators-error" class="text-red-500 text-sm mt-1 hidden"></p>
    </div>

    <!-- Monthly Budget (Optional) -->
    <div>
      <label for="monthly_budget" class="block text-sm font-medium text-gray-700 mb-2">
        Orçamento Mensal (Opcional)
      </label>
      <input
        type="number"
        id="monthly_budget"
        name="monthly_budget"
        placeholder="Ex: 5000"
        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition"
        min="0"
        step="0.01"
      />
      <p id="monthly_budget-error" class="text-red-500 text-sm mt-1 hidden"></p>
    </div>

    <!-- Form Error Alert -->
    <div id="formError" class="hidden bg-red-50 border border-red-200 rounded-lg p-4">
      <p class="text-red-800 font-medium">⚠️ Erro ao enviar formulário</p>
      <p id="formErrorMessage" class="text-red-700 text-sm mt-1"></p>
    </div>

    <!-- Form Success Alert -->
    <div id="formSuccess" class="hidden bg-green-50 border border-green-200 rounded-lg p-4">
      <p class="text-green-800 font-bold">✅ Briefing enviado com sucesso!</p>
      <p id="formSuccessMessage" class="text-green-700 text-sm mt-1"></p>
    </div>

    <!-- Submit Button -->
    <div class="pt-4">
      <button
        type="submit"
        id="submitBtn"
        class="w-full bg-blue-600 hover:bg-blue-700 disabled:bg-gray-400 disabled:cursor-not-allowed text-white font-bold py-3 rounded-lg transition duration-200"
      >
        Enviar Briefing
      </button>
      <p id="submitting" class="text-center text-gray-600 text-sm mt-2 hidden">
        Enviando formulário...
      </p>
    </div>
  </form>
</div>

<script define:vars={{ clientId, apiKey }}>
  import { validateForm } from '../lib/briefing-form-validation';

  const form = document.getElementById('briefingForm');
  const submitBtn = document.getElementById('submitBtn');
  const submitting = document.getElementById('submitting');
  const formError = document.getElementById('formError');
  const formErrorMessage = document.getElementById('formErrorMessage');
  const formSuccess = document.getElementById('formSuccess');
  const formSuccessMessage = document.getElementById('formSuccessMessage');

  // Helper to clear field errors
  function clearFieldError(fieldName) {
    const errorEl = document.getElementById(`${fieldName}-error`);
    if (errorEl) {
      errorEl.textContent = '';
      errorEl.classList.add('hidden');
    }
  }

  // Helper to show field error
  function showFieldError(fieldName, message) {
    const errorEl = document.getElementById(`${fieldName}-error`);
    if (errorEl) {
      errorEl.textContent = message;
      errorEl.classList.remove('hidden');
    }
  }

  // Clear form error messages
  function clearFormMessages() {
    formError.classList.add('hidden');
    formSuccess.classList.add('hidden');
  }

  // Get form data as object
  function getFormData() {
    const formData = new FormData(form);
    const data = {
      business_name: formData.get('business_name'),
      segment: formData.get('segment'),
      target_audience: formData.get('target_audience'),
      voice_tone: formData.get('voice_tone'),
      objectives: formData.getAll('objectives'),
      differentiators: formData.get('differentiators'),
    };

    const budget = formData.get('monthly_budget');
    if (budget) {
      data.monthly_budget = parseFloat(budget);
    }

    return data;
  }

  // Form submit handler
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    clearFormMessages();

    // Validate form
    const formData = getFormData();
    const validation = validateForm(formData);

    if (!validation.valid) {
      // Show field errors
      Object.entries(validation.errors).forEach(([field, message]) => {
        showFieldError(field, message);
      });
      return;
    }

    // Clear field errors on successful validation
    ['business_name', 'segment', 'target_audience', 'voice_tone', 'objectives', 'differentiators', 'monthly_budget'].forEach(
      (field) => clearFieldError(field)
    );

    // Submit to API
    submitBtn.disabled = true;
    submitting.classList.remove('hidden');

    try {
      // Use dynamic client ID from page if available, otherwise use prop
      const activeClientId = window.ACTIVE_CLIENT_ID || clientId;

      const response = await fetch('/briefings', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-API-Key': apiKey || import.meta.env.PUBLIC_API_KEY || '',
        },
        body: JSON.stringify({
          client_id: activeClientId,
          ...formData,
        }),
      });

      if (response.ok) {
        const result = await response.json();
        formSuccessMessage.textContent = `ID do Briefing: ${result.id || 'Criado com sucesso'}`;
        formSuccess.classList.remove('hidden');

        // Reset form
        form.reset();

        // Hide success message after 5 seconds
        setTimeout(() => {
          formSuccess.classList.add('hidden');
        }, 5000);
      } else {
        const error = await response.json();
        const errorMsg =
          error.message ||
          error.details?.message ||
          `Erro ao enviar briefing (${response.status})`;
        formErrorMessage.textContent = errorMsg;
        formError.classList.remove('hidden');
      }
    } catch (err) {
      console.error('Form submission error:', err);
      formErrorMessage.textContent =
        err instanceof Error ? err.message : 'Erro desconhecido ao enviar formulário';
      formError.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitting.classList.add('hidden');
    }
  });

  // Clear error on field change
  form.addEventListener('change', (e) => {
    const target = e.target;
    if (target instanceof HTMLInputElement || target instanceof HTMLSelectElement || target instanceof HTMLTextAreaElement) {
      clearFieldError(target.name);
    }
  });
</script>
